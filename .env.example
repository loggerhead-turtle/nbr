# ─────────────────────────────────────────────────────────────────────────────
# Database (Supabase Postgres)
# Use the POOLED connection string (pgBouncer, port 6543) for the app runtime,
# and the DIRECT connection string (port 5432) for migrations.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@host:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:password@host:5432/postgres"

# ─────────────────────────────────────────────────────────────────────────────
# Web app
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Comma-separated list of admin emails allowed into /admin (MVP gate).
ADMIN_ALLOWLIST="public@erikpaul.net"
# Shared secret for the simple MVP admin login (replaced by NextAuth in Phase 2).
ADMIN_PASSWORD="change-me"
# Secret used to sign the admin session cookie.
ADMIN_SESSION_SECRET="generate-a-long-random-string"

# ─────────────────────────────────────────────────────────────────────────────
# Scraper worker
# ─────────────────────────────────────────────────────────────────────────────
# Global kill switch. Set to "true" to allow scraping; anything else disables it.
SCRAPER_ENABLED="false"
# Max teams to scrape in a single run (politeness cap).
SCRAPER_MAX_TEAMS_PER_RUN="25"
# Hours after a game's scheduled end before we fetch its final score.
SCRAPER_POSTGAME_DELAY_HOURS="2.5"
# Optional path to a system Chromium (e.g. Render Docker / Playwright cache).
# PLAYWRIGHT_BROWSERS_PATH="/opt/pw-browsers"

# ─────────────────────────────────────────────────────────────────────────────
# Rating engine
# ─────────────────────────────────────────────────────────────────────────────
# Model used by `worker recompute`: "bt-mov-v1" (global Bradley-Terry, default)
# or "glicko2-v1" (sequential baseline).
RATING_ALGORITHM="bt-mov-v1"
# Recency half-life in days for the Bradley-Terry model.
RATING_HALF_LIFE_DAYS="120"
# Held-out window (days) for `worker backtest`.
BACKTEST_WINDOW_DAYS="21"

# ─────────────────────────────────────────────────────────────────────────────
# Email notifications (optional). If RESEND_API_KEY is unset, emails are logged
# and skipped (the app still works). Get a key at resend.com and verify a sender.
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="National Baseball Ratings <noreply@yourdomain.com>"
# Where admin notifications (e.g. tournament-director requests) are sent.
# Falls back to the first address in ADMIN_ALLOWLIST if unset.
ADMIN_NOTIFY_EMAIL="public@erikpaul.net"

# ─────────────────────────────────────────────────────────────────────────────
# Geocoding (optional, Phase 2 proximity). Leave blank to skip geocoding.
# ─────────────────────────────────────────────────────────────────────────────
GEOCODER_USER_AGENT="nbr-geocoder (public@erikpaul.net)"
