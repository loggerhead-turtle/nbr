// National Baseball Ratings — Prisma schema
// MVP tables + Phase 2 tables (users / claims / reports / scrimmage) defined up
// front so Phase 2 is an additive migration. See docs/DESIGN notes in the repo.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum AgeGroup {
  U8
  U9
  U10
  U11
  U12
  U13
  U14
  U15
  U16
  U17
  U18
  OPEN
}

enum GameStatus {
  SCHEDULED
  FINAL
  CANCELED
}

enum GameSource {
  SCRAPE
  MANUAL
}

enum RunStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum ScrapeStatus {
  SUCCESS
  FAILED
  BLOCKED
  EMPTY
}

enum UserRole {
  USER
  ADMIN
  // Limited staff login: may add games and use the GameChanger lookup (add
  // teams), plus manage their own account. No other admin access.
  GAME_SCRAPER
}

enum ClaimStatus {
  PENDING
  APPROVED
  REVOKED
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

// ─────────────────────────────────────────────────────────────────────────────
// Core (MVP)
// ─────────────────────────────────────────────────────────────────────────────

model Team {
  id       String    @id @default(cuid())
  name     String
  // GameChanger opaque team id (e.g. "21nCCNFQXjHB"). Null for manual/ghost teams.
  gcTeamId String?   @unique
  // URL-safe slug for SEO team pages, e.g. "slc-thunder-12u".
  slug     String    @unique
  ageGroup AgeGroup?
  division String?
  // High-school varsity classification ("1A".."6A"). When set, the team is a
  // varsity team rather than a youth (age-group) team.
  classification String?
  // MaxPreps team page URL (data source for high-school varsity teams).
  maxprepsUrl    String? @unique

  // Coaching staff parsed from the team's own GameChanger page ("Staff: ..."),
  // used as a merge-confidence signal (same name + same coach ⇒ same club).
  coaches  String[] @default([])

  // Location (city/state shown publicly; zip + lat/long power Phase 2 proximity).
  city      String?
  state     String  @default("UT")
  zip       String?
  latitude  Float?
  longitude Float?
  // Set when an admin has manually edited or removed the location. The scraper
  // then leaves city/coords alone (GameChanger sometimes reports a tournament's
  // host city instead of the team's home), and geocoding is skipped.
  locationLocked Boolean @default(false)

  // Team's own external website (optional). The GameChanger page is derived from
  // gcTeamId; season-to-season website history comes from the succession chain.
  website   String?

  // Captured verbatim from the team's GameChanger page header (for provenance and
  // future season/succession logic). gcSeason is GC's own label, e.g.
  // "Spring 2026" / "Fall 2025" — note a team may keep one GC team across several
  // real seasons, so this is the label GC assigned, not a strict period. gcRecord
  // is GC's stated W-L, e.g. "16-17".
  gcSeason  String?
  gcRecord  String?

  isActive Boolean @default(true)
  // Ghost teams are opponents auto-created from scraped games before an admin
  // has formally added/enriched them. They still contribute to ratings.
  isGhost  Boolean @default(false)
  // Set when a team was quick-added by GameChanger ID only; the scraper fills in
  // the real name/city/age group from the team's page on its first run.
  needsEnrichment Boolean @default(false)
  // Set when the team has a confident, un-dismissed ghost match awaiting review
  // on the Merge queue. Its games still count in ratings; the public "Verifying"
  // badge flags that the record may gain games once an admin approves the merge.
  // Cleared when the match is approved (merged) or dismissed.
  pendingMerge    Boolean @default(false)

  // Cross-season succession: most clubs register a NEW GameChanger team each
  // season (13U → 14U). The new season-team points to the prior one so its
  // rating/record carry forward; the old team is archived (isActive=false).
  seasonYear        Int?
  predecessorTeamId String? @unique
  predecessor       Team?   @relation("TeamSuccession", fields: [predecessorTeamId], references: [id], onDelete: SetNull)
  successor         Team?   @relation("TeamSuccession")

  // Scraper controls.
  scrapeEnabled       Boolean   @default(true)
  lastScrapedAt       DateTime?
  consecutiveFailures Int       @default(0)
  // When the team appears dormant, the scraper backs off; this is the earliest
  // time the team should be checked again.
  nextScrapeAfter     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  homeGames     Game[]          @relation("HomeTeam")
  awayGames     Game[]          @relation("AwayTeam")
  rating        Rating?
  ratingHistory RatingHistory[]
  scrapeJobs    ScrapeJob[]

  // Phase 2 relations
  claim            Claim?
  reports          Report[]
  scrimmagePref    ScrimmagePref?
  tournamentInvites TournamentInvite[]
  scrapeCredit     ScrapeCredit?

  @@index([state, ageGroup])
  @@index([classification])
  @@index([isGhost])
  @@index([scrapeEnabled, nextScrapeAfter])
}

model Game {
  id String @id @default(cuid())
  // GameChanger opaque game id; the hard dedup key. Null for manual entries.
  gcGameId String? @unique

  homeTeamId String
  awayTeamId String
  homeTeam   Team   @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam   Team   @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)

  homeScore Int?
  awayScore Int?
  status    GameStatus @default(SCHEDULED)
  playedAt  DateTime
  // Tournament/neutral games skip the home-field adjustment in the rating engine.
  neutralSite Boolean @default(false)

  source GameSource @default(SCRAPE)
  // The team whose scrape produced this row. Lets us tell a real doubleheader
  // (two legs from the SAME team's schedule) apart from a cross-team duplicate
  // (one game listed on both teams' schedules) — the two look identical by
  // opponent + day + score, so the source is the only reliable discriminator.
  // Null for manual entries and rows created before this column existed.
  sourceTeamId String?
  // Set when a rating run has incorporated this game (enables idempotent reruns).
  ratedAt DateTime?

  createdByUserId String? // Phase 2 audit for manual entries
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, playedAt])
  @@index([homeTeamId, playedAt])
  @@index([awayTeamId, playedAt])
}

// Current/latest rating per team — read-optimized for the public ratings page.
model Rating {
  id     String @id @default(cuid())
  teamId String @unique
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  rating      Float @default(1500)
  rd          Float @default(350)
  volatility  Float @default(0.06)
  gamesPlayed Int   @default(0)
  // Provisional while RD is high or games are few; flagged/demoted in rankings.
  isProvisional Boolean @default(true)

  wins   Int @default(0)
  losses Int @default(0)
  ties   Int @default(0)

  // Connected-component id from the game graph (ratings only comparable within).
  componentId String?

  computedAt DateTime @default(now())

  @@index([rating])
  @@index([isProvisional, rating])
  @@index([componentId])
}

// Append-only snapshot, one row per team per rating run — powers history charts.
model RatingHistory {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  rating      Float
  rd          Float
  volatility  Float
  gamesPlayed Int

  runId String
  run   RatingRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  asOf  DateTime  @default(now())

  @@index([teamId, asOf])
  @@index([runId])
}

// One row per recompute job execution — observability + reproducibility.
model RatingRun {
  id               String    @id @default(cuid())
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?
  status           RunStatus @default(RUNNING)
  gamesProcessed   Int       @default(0)
  teamsAffected    Int       @default(0)
  algorithmVersion String    @default("glicko2-v1")
  error            String?

  history RatingHistory[]

  @@index([startedAt])
}

// Scraper audit + politeness observability.
model ScrapeJob {
  id     String  @id @default(cuid())
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  startedAt  DateTime     @default(now())
  finishedAt DateTime?
  status     ScrapeStatus @default(SUCCESS)
  gamesFound Int          @default(0)
  gamesNew   Int          @default(0)
  httpStatus Int?
  error      String?

  @@index([teamId, startedAt])
  @@index([status, startedAt])
}

// Optional persistence for shareable pool-generator results (no auth needed).
model TournamentPool {
  id        String   @id @default(cuid())
  token     String   @unique // unguessable share token for /pools/{token}
  name      String?
  numPools  Int
  config    Json // snapshot of selected teams + ratings at generation time
  result    Json // computed pool assignments + balance metrics
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Simple key/value app settings (e.g. currentSeasonYear for rollover).
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Admin "don't merge" decisions so dismissed duplicate pairs don't resurface.
// Pair is stored canonically (teamIdA < teamIdB).
model DuplicateDismissal {
  id        String   @id @default(cuid())
  teamIdA   String
  teamIdB   String
  createdAt DateTime @default(now())

  @@unique([teamIdA, teamIdB])
}

// A same-day matchup where the two teams' schedules disagree on how many games
// they played each other (e.g. one lists a doubleheader, the other lists one
// game). We can't tell a real doubleheader from a double-entered single game, so
// the matchup is parked here for an admin to resolve on the Game merge queue
// instead of silently collapsing (which would drop a real game) or feeding the
// team Duplicates page (which would falsely suggest the teams are the same
// record). Teams stored canonically (teamIdA < teamIdB); one row per matchup+day.
model GameMergeCandidate {
  id      String @id @default(cuid())
  teamIdA String
  teamIdB String
  // The calendar day of the matchup, "YYYY-MM-DD".
  day String
  // How many games each side's own schedule lists for this matchup that day.
  countA Int
  countB Int
  // "open" (needs review) or "resolved" (an admin acted / dismissed it).
  status     String    @default("open")
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([teamIdA, teamIdB, day])
  @@index([status])
}

// A run of the background duplicate-backlog merge (worker-driven). Records the
// confidence threshold used and how many pairs were merged, so an admin can
// watch progress and audit what happened on the Duplicates backlog page.
model DuplicateMergeRun {
  id            String    @id @default(cuid())
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  status        RunStatus @default(RUNNING)
  // Minimum merge confidence (%) a pair needed to be merged in this run.
  minConfidence Int
  merged        Int       @default(0)
  scanned       Int       @default(0)
  error         String?

  logs DuplicateMergeLog[]

  @@index([startedAt])
}

// One folded-in duplicate: which record merged into which, at what confidence.
model DuplicateMergeLog {
  id         String            @id @default(cuid())
  runId      String
  run        DuplicateMergeRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  mergedAt   DateTime          @default(now())
  // The kept (verified) team the duplicate folded into.
  keptTeamId String?
  keptName   String
  // The duplicate (ghost) record that was removed.
  mergedName String
  confidence Int
  gamesMoved Int               @default(0)

  @@index([runId, mergedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 2 — users / claims / reports / scrimmage.
// Defined now so they require only additive migrations; not wired into the MVP UI.
// NextAuth-compatible Account/Session/VerificationToken included for later use.
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  firstName     String?
  lastName      String?
  email         String    @unique
  phone         String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)

  // Tournament-director status + profile.
  tdStatus         String    @default("NONE") // NONE | REQUESTED | APPROVED | REJECTED
  tdOrg            String?
  tdWebsite        String?
  tdTournamentName String?
  tdRequestedAt    DateTime?

  // Saved default filters for the front-page scrimmage finder (JSON string).
  scrimmageDefaults String?

  // Most recent successful login — powers the admin activity feed.
  lastLoginAt   DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  claims        Claim[]
  reports       Report[]
  scrimmagePref ScrimmagePref[]
  tournaments   Tournament[]
  umpire        Umpire?
  scrapeCredits ScrapeCredit[]
  payouts       Payout[]
}

// One paid "team added" event: the game-scraper who added a team, with the pay
// rate snapshotted at add time so historical pay is stable if the rate changes.
model ScrapeCredit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // The team that was added. Nullable + SetNull so pay history survives a later
  // team delete/merge; gcTeamId keeps a stable reference either way.
  teamId    String?  @unique
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  gcTeamId  String?
  rateCents Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// A payout an admin recorded for a scraper. `paidThrough` marks the cutoff:
// credits at or before it are considered paid, so "since last pay period" is the
// sum of credits after the latest payout's paidThrough.
model Payout {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountCents Int
  teamsCount  Int      @default(0)
  paidThrough DateTime
  note        String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

model Tournament {
  id             String   @id @default(cuid())
  directorUserId String
  director       User     @relation(fields: [directorUserId], references: [id], onDelete: Cascade)
  name           String
  createdAt      DateTime @default(now())

  // Logistics + status. DRAFT while building, OPEN once invites go out,
  // FINALIZED once the roster is locked and pools/schedule are generated.
  status         String    @default("DRAFT") // DRAFT | OPEN | FINALIZED
  startDate      DateTime?
  location       String?
  // Payment structure (illustration only — no real processing). Dollars.
  entryFee       Int?
  depositAmount  Int?
  // Scheduling config.
  poolPlayGames  Int       @default(3)
  allowCrossover Boolean   @default(false)

  invites      TournamentInvite[]
  divisions    TournamentDivision[]
  fields       Field[]
  scheduleGames ScheduleGame[]

  @@index([directorUserId])
}

// One competition group within a tournament: an age group at a given NBR level.
// Two divisions may share an ageGroup with different nbrLevel labels (the
// "two tournaments in one" concept — e.g. "12U · NBR I" and "12U · NBR II").
model TournamentDivision {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  ageGroup     AgeGroup
  nbrLevel     String     @default("NBR I")
  // Target NBR band used to pre-fill the team search for this division.
  nbrMin       Int?
  nbrMax       Int?
  // Cached generatePools() output (PoolResult JSON) once pools are built.
  poolsJson    Json?
  // Cached buildBracket() output (rounds JSON) once a bracket is built.
  bracketJson  Json?
  createdAt    DateTime   @default(now())

  invites         TournamentInvite[]
  scheduleGames   ScheduleGame[]
  advancementRule AdvancementRule?

  @@index([tournamentId])
}

// A playing field/diamond available to a tournament.
model Field {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String
  hasLights    Boolean    @default(false)
  // Which age groups this field is suitable to host (base-path/fence sizing).
  allowedAgeGroups AgeGroup[]
  // Private, TD-only communications/notes (groundskeeper contacts, gate codes…).
  privateNotes String     @default("")
  createdAt    DateTime   @default(now())

  scheduleGames ScheduleGame[]

  @@index([tournamentId])
}

// A scheduled pool-play (or crossover) game on a field at a time slot.
model ScheduleGame {
  id           String             @id @default(cuid())
  tournamentId String
  tournament   Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  divisionId   String
  division     TournamentDivision @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  // Pool label ("Pool A") for pool play; null for crossover games.
  poolLabel    String?
  fieldId      String?
  field        Field?             @relation(fields: [fieldId], references: [id], onDelete: SetNull)
  slotLabel    String // e.g. "Sat 9:00 AM"
  // Team ids (real Team ids, or demo placeholder ids). Stored as scalars — no FK
  // so demo/real data and historical rosters stay decoupled from Team lifecycle.
  homeTeamId   String
  homeTeamName String
  awayTeamId   String
  awayTeamName String
  isCrossover  Boolean            @default(false)
  umpireId     String?
  umpire       Umpire?            @relation(fields: [umpireId], references: [id], onDelete: SetNull)
  createdAt    DateTime           @default(now())

  @@index([tournamentId])
  @@index([divisionId])
}

// An umpire in the pool. Optionally linked to a User for self-service.
model Umpire {
  id                  String    @id @default(cuid())
  userId              String?   @unique
  user                User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  name                String
  email               String?
  ageGroups           AgeGroup[]
  available           Boolean   @default(true)
  willUmpireScrimmages Boolean  @default(false)
  createdAt           DateTime  @default(now())

  scheduleGames ScheduleGame[]
  notes         UmpireNote[]
  feedback      UmpireFeedback[]
}

// TD-only private evaluation notes about an umpire.
model UmpireNote {
  id             String   @id @default(cuid())
  umpireId       String
  umpire         Umpire   @relation(fields: [umpireId], references: [id], onDelete: Cascade)
  directorUserId String
  body           String
  createdAt      DateTime @default(now())

  @@index([umpireId, createdAt])
}

// Future release: confidential coach → umpire feedback (Likert + one comment).
// Schema present now; the coach-facing UI is stubbed/disabled this release.
model UmpireFeedback {
  id           String   @id @default(cuid())
  umpireId     String
  umpire       Umpire   @relation(fields: [umpireId], references: [id], onDelete: Cascade)
  fromUserId   String?
  likert       Int // 1..5
  comment      String?
  confidential Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([umpireId])
}

// Bracket advancement rules a division uses. presetKey identifies a built-in
// preset; isCustom marks a director-authored rule.
model AdvancementRule {
  id                String             @id @default(cuid())
  divisionId        String             @unique
  division          TournamentDivision @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  presetKey         String? // e.g. "balanced" | "pool-winners" | "wildcard"
  name              String
  synopsis          String
  poolWinnersAdvance Int               @default(1)
  wildcards         Int                @default(0)
  seedBy            String             @default("POOL_RECORD") // POOL_RECORD | RATING | RUN_DIFF
  reseed            Boolean            @default(true)
  isCustom          Boolean            @default(false)
}

model TournamentInvite {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamId       String
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  status       String     @default("INVITED") // INVITED | ACCEPTED | DECLINED
  // Which division (age + NBR level) the team is invited into.
  divisionId   String?
  division     TournamentDivision? @relation(fields: [divisionId], references: [id], onDelete: SetNull)
  // Payment + roster standing (illustration). PENCILED = tentatively penciled in.
  paymentStatus String    @default("PENCILED") // PENCILED | INVITED | DEPOSIT_PAID | PAID
  createdAt    DateTime   @default(now())

  // Conversation thread between the tournament director and the team's coach.
  directorReadAt     DateTime?
  teamReadAt         DateTime?
  directorShareEmail Boolean @default(false)
  directorSharePhone Boolean @default(false)
  teamShareEmail     Boolean @default(false)
  teamSharePhone     Boolean @default(false)
  messages           TournamentMessage[]

  @@unique([tournamentId, teamId])
  @@index([teamId, status])
}

// A message in a tournament invite's director↔coach conversation thread.
model TournamentMessage {
  id           String           @id @default(cuid())
  inviteId     String
  invite       TournamentInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  senderUserId String
  body         String
  createdAt    DateTime         @default(now())

  @@index([inviteId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Claim {
  id     String @id @default(cuid())
  teamId String @unique // one active claim per team
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status ClaimStatus @default(PENDING)
  // Claimer's first/last name is public; email/phone revealed only to registered
  // users AND only when the coach opts in.
  contactOptIn Boolean @default(false)

  createdAt  DateTime  @default(now())
  approvedAt DateTime?

  reports Report[]
}

model Report {
  id           String       @id @default(cuid())
  teamId       String
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  claimId      String?
  claim        Claim?       @relation(fields: [claimId], references: [id], onDelete: SetNull)
  reporterUserId String?
  reporter     User?        @relation(fields: [reporterUserId], references: [id], onDelete: SetNull)
  reason       String
  details      String?
  status       ReportStatus @default(OPEN)
  createdAt    DateTime     @default(now())

  @@index([status, createdAt])
}

model ScrimmageRequest {
  id         String   @id @default(cuid())
  fromTeamId String
  toTeamId   String
  fromUserId String
  message    String?
  status     String   @default("PENDING") // PENDING | ACCEPTED | DECLINED
  createdAt  DateTime @default(now())

  // Thread read state per side (from = initiator, to = recipient coach).
  fromReadAt DateTime?
  toReadAt   DateTime?
  // Per-thread contact sharing each side opts into (revocable).
  fromShareEmail Boolean @default(false)
  fromSharePhone Boolean @default(false)
  toShareEmail   Boolean @default(false)
  toSharePhone   Boolean @default(false)

  messages ScrimmageMessage[]

  @@index([toTeamId, status])
  @@index([fromTeamId])
}

// A message in a scrimmage request's conversation thread.
model ScrimmageMessage {
  id           String           @id @default(cuid())
  requestId    String
  request      ScrimmageRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  senderUserId String
  body         String
  createdAt    DateTime         @default(now())

  @@index([requestId, createdAt])
}

model ScrimmagePref {
  id     String @id @default(cuid())
  teamId String @unique
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  seekingScrimmage Boolean @default(false)
  maxDistanceMiles Int?
  notes            String?

  updatedAt DateTime @updatedAt
}
